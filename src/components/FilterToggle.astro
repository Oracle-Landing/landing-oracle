---
// Client-side filter toggle — Live / All pills
---

<div class="inline-flex rounded-full p-0.5 glass" id="filter-toggle">
  <button
    id="filter-live"
    class="filter-pill active"
    data-filter="live"
  >
    Live
  </button>
  <button
    id="filter-all"
    class="filter-pill"
    data-filter="all"
  >
    All
  </button>
</div>

<style>
  .filter-pill {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--theme-text-muted);
    transition: all 0.2s ease;
    cursor: pointer;
    background: transparent;
    border: none;
  }
  .filter-pill:hover {
    color: var(--theme-text);
  }
  .filter-pill.active {
    background: rgba(var(--theme-primary-rgb), 0.2);
    color: var(--theme-primary);
  }
</style>

<script>
  import { $filter, setFilter, initFilter, type FilterMode } from "../stores/filter";

  initFilter();

  const liveBtn = document.getElementById("filter-live")!;
  const allBtn = document.getElementById("filter-all")!;

  function applyFilter(mode: FilterMode) {
    // Update pill state
    liveBtn.classList.toggle("active", mode === "live");
    allBtn.classList.toggle("active", mode === "all");

    // Show/hide cards
    const cards = document.querySelectorAll<HTMLElement>(".gallery-card");
    cards.forEach((card) => {
      const status = card.dataset.status;
      if (mode === "live" && status === "known") {
        card.style.display = "none";
      } else {
        card.style.display = "";
      }
    });

    // Update subtitle count
    const subtitle = document.getElementById("gallery-subtitle");
    if (subtitle) {
      const visible = document.querySelectorAll<HTMLElement>('.gallery-card:not([style*="display: none"])').length;
      const liveCount = document.querySelectorAll('.gallery-card[data-status="live"]').length;
      if (mode === "live") {
        subtitle.textContent = `${liveCount} live \u00b7 76+ in the family`;
      } else {
        subtitle.textContent = `${visible} shown \u00b7 76+ in the family`;
      }
    }
  }

  // Apply initial state
  applyFilter($filter.get());

  // Listen for changes
  $filter.subscribe(applyFilter);

  // Button handlers
  liveBtn.addEventListener("click", () => setFilter("live"));
  allBtn.addEventListener("click", () => setFilter("all"));
</script>
