---
interface Props {
  name: string;
  number?: string;
  domain: string;
  primary: string;
  secondary: string;
  background: string;
  stack: string[];
  live: boolean;
}

const { name, number, domain, primary, secondary, background, stack, live } = Astro.props;
const url = `https://${domain}`;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="glass-card block group relative overflow-hidden"
>
  <!-- Color bar -->
  <div
    class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl"
    style={`background: linear-gradient(90deg, ${primary}, ${secondary})`}
  ></div>

  <!-- Header -->
  <div class="flex items-start justify-between mb-3 pt-2">
    <div>
      <h3 class="font-semibold text-[var(--theme-text)] group-hover:text-[var(--theme-primary)] transition-colors">
        {name}
      </h3>
      {number && <span class="text-xs text-[var(--theme-text-muted)]">#{number}</span>}
    </div>
    {live && (
      <span class="flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-glow"></span>
        LIVE
      </span>
    )}
  </div>

  <!-- Domain -->
  <p class="text-xs text-[var(--theme-text-muted)] mb-3 font-mono truncate">{domain}</p>

  <!-- Color swatches -->
  <div class="flex items-center gap-2 mb-3">
    <div class="flex gap-1">
      <div class="w-4 h-4 rounded-full border border-white/10" style={`background:${primary}`} title={`Primary: ${primary}`}></div>
      <div class="w-4 h-4 rounded-full border border-white/10" style={`background:${secondary}`} title={`Secondary: ${secondary}`}></div>
      <div class="w-4 h-4 rounded-full border border-white/10" style={`background:${background}`} title={`Background: ${background}`}></div>
    </div>
  </div>

  <!-- Stack tags -->
  <div class="flex flex-wrap gap-1">
    {stack.map((tag) => (
      <span class="text-[10px] px-1.5 py-0.5 rounded bg-[var(--theme-primary)]/10 text-[var(--theme-text-muted)]">
        {tag}
      </span>
    ))}
  </div>
</a>
