---
interface Props {
  oracle: {
    name: string;
    number?: string;
    primary: string;
    secondary: string;
    background: string;
    status: "live" | "known";
  };
}

const { oracle } = Astro.props;
---

<div
  class="gallery-card relative rounded-2xl overflow-hidden p-5"
  data-status="known"
  style={`background: linear-gradient(135deg, ${oracle.primary}15, ${oracle.secondary}10); border: 1px solid ${oracle.primary}20;`}
>
  <!-- Color accent bar -->
  <div
    class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl"
    style={`background: linear-gradient(90deg, ${oracle.primary}, ${oracle.secondary})`}
  ></div>

  <!-- Content -->
  <div class="flex items-center justify-between">
    <div>
      <h3 class="font-semibold text-[var(--theme-text)] text-sm">{oracle.name}</h3>
      {oracle.number && (
        <span class="text-xs text-[var(--theme-text-muted)]">#{oracle.number}</span>
      )}
    </div>
    <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-[var(--theme-primary)]/10 text-[var(--theme-text-muted)]">
      Coming Soon
    </span>
  </div>

  <!-- Color swatches -->
  <div class="flex gap-1 mt-3">
    <div class="w-3 h-3 rounded-full" style={`background: ${oracle.primary}`}></div>
    <div class="w-3 h-3 rounded-full" style={`background: ${oracle.secondary}`}></div>
  </div>
</div>
