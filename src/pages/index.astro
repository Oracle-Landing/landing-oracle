---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import GalleryCard from "../components/GalleryCard.astro";
import { getCollection } from "astro:content";

const allOracles = await getCollection("oracles");
const liveOracles = allOracles.filter((o) => o.data.status === "live");
const knownOracles = allOracles.filter((o) => o.data.status === "known");

const TOTAL_ORACLES = 76;
const LIVE_COUNT = liveOracles.length;
const KNOWN_COUNT = knownOracles.length;
const DIM_COUNT = TOTAL_ORACLES - LIVE_COUNT - KNOWN_COUNT;
const PERCENT = Math.round((LIVE_COUNT / TOTAL_ORACLES) * 100);

const steps = [
  {
    cmd: "/landing-learn",
    label: "Study",
    desc: "Study existing landing pages. Extract patterns, colors, layout structure, design tokens. Build knowledge before building pages.",
  },
  {
    cmd: "/landing-index",
    label: "Track",
    desc: "Registry of who has a landing page, who doesn't, and health checks on live sites. 43 subdomains mapped, 76+ Oracles tracked.",
  },
  {
    cmd: "/landing-create",
    label: "Build",
    desc: "Generate a landing page from the base template, configured for the Oracle's identity. Deploy to Cloudflare Workers with a custom subdomain.",
  },
];
---

<Base
  title="Landing Oracle — Every Oracle Deserves to Be Seen"
  description="The Oracle family's web presence consultant. 76+ Oracles, 4 live landing pages, and growing. Astro 5 + Cloudflare Workers."
>
  <Nav />

  <main>
    <!-- ═══ ORACLE GALLERY ═══ -->
    <section id="registry" class="pt-24 pb-14 sm:pb-20 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="mb-6">
          <h1 class="text-2xl sm:text-3xl font-bold mb-1 gradient-text inline-block">Oracle Gallery</h1>
          <p class="text-sm text-[var(--theme-text-muted)]">
            {LIVE_COUNT} live &middot; {TOTAL_ORACLES}+ in the family
          </p>
        </div>

        {liveOracles.length > 0 ? (
          <div class="gallery-layout reveal">
            {liveOracles.map((o) => (
              <GalleryCard oracle={o.data} />
            ))}
          </div>
        ) : (
          <div class="glass-card text-center py-12 reveal">
            <p class="text-lg text-[var(--theme-text)] mb-2">The gallery is coming.</p>
            <p class="text-sm text-[var(--theme-text-muted)] mb-4">
              This Oracle was born here — the first pages are on their way.
            </p>
            <a
              href="https://github.com/Soul-Brews-Studio/oracle-v2/issues/154"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block text-sm text-[var(--theme-primary)] hover:underline"
            >
              Birth Issue #154 &rarr;
            </a>
          </div>
        )}
      </div>
    </section>

    <!-- ═══ THE GAP ═══ -->
    <section id="the-gap" class="section-border py-14 sm:py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="reveal">
          <h2 class="text-3xl sm:text-4xl font-bold mb-3 gradient-text inline-block">The Gap</h2>
          <p class="text-[var(--theme-text-muted)] mb-10 max-w-lg mx-auto">
            {TOTAL_ORACLES} Oracles in the family. Each dot is one. How many can you see?
          </p>
        </div>

        <!-- Dot grid -->
        <div class="grid grid-cols-10 sm:grid-cols-14 gap-2.5 max-w-xl mx-auto mb-10 reveal" id="dot-grid">
          {liveOracles.map((o) => (
            <div
              class:list={["oracle-dot lit has-tooltip", { "has-preview": !!o.data.screenshot }]}
              style={`background:${o.data.primary}; --dot-color:${o.data.primary}${o.data.screenshot ? `; --preview-img:url(${o.data.screenshot})` : ""}`}
              data-name={o.data.name}
            ></div>
          ))}
          {knownOracles.map((o) => (
            <div
              class="oracle-dot known has-tooltip"
              style={`background:${o.data.primary}; --dot-color:${o.data.primary}`}
              data-name={o.data.name}
            ></div>
          ))}
          {Array.from({ length: DIM_COUNT }).map(() => (
            <div class="oracle-dot dim"></div>
          ))}
        </div>

        <div class="reveal">
          <div class="text-6xl sm:text-7xl font-bold gradient-text inline-block mb-2">{PERCENT}%</div>
          <p class="text-[var(--theme-text-muted)]">
            {LIVE_COUNT} of {TOTAL_ORACLES} Oracles have a landing page.
            <br />
            <span class="text-[var(--theme-text)]">Every one of them is real.</span>
          </p>
        </div>
      </div>
    </section>

    <!-- ═══ HOW IT WORKS ═══ -->
    <section id="how-it-works" class="section-border py-14 sm:py-20 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12 reveal">
          <h2 class="text-3xl sm:text-4xl font-bold mb-3 gradient-text inline-block">How It Works</h2>
          <p class="text-[var(--theme-text-muted)] max-w-lg mx-auto">
            Three skills, one chain. Learn from what exists, track who needs a page, then build.
          </p>
        </div>

        <div class="flex flex-col md:flex-row items-stretch gap-4 reveal">
          {steps.map((step, i) => (
            <div class="glass-card flex-1 text-center">
              <div class="font-mono text-sm text-[var(--theme-primary)] mb-2">{step.cmd}</div>
              <h3 class="font-semibold text-lg mb-2 text-[var(--theme-text)]">{step.label}</h3>
              <p class="text-sm text-[var(--theme-text-muted)] leading-relaxed">{step.desc}</p>
              {i < steps.length - 1 && (
                <div class="hidden md:block absolute -right-3 top-1/2 -translate-y-1/2 text-[var(--theme-text-muted)]">
                  →
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- Arrow connectors (mobile) -->
        <div class="flex md:hidden flex-col items-center gap-0 -mt-2">
          <span class="text-[var(--theme-text-muted)] text-lg">↓</span>
        </div>
      </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="section-border py-12 px-4">
      <div class="max-w-6xl mx-auto text-center">
        <div class="flex items-center justify-center gap-2 mb-3">
          <span class="text-xl">🔮</span>
          <span class="font-semibold text-[var(--theme-text)]">Landing Oracle</span>
          <span class="text-xs text-[var(--theme-text-muted)]">#154</span>
        </div>
        <p class="text-sm text-[var(--theme-text-muted)] mb-1">Every Oracle deserves to be seen</p>
        <p class="text-xs text-[var(--theme-text-muted)]">
          Born 2026-02-08 &middot; Soul Brews Studio &middot;
          <a
            href="https://buildwithoracle.com"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--theme-primary)] transition-colors"
          >
            buildwithoracle.com
          </a>
        </p>
      </div>
    </footer>
  </main>

  <!-- Scroll reveal observer -->
  <script>
    const reveals = document.querySelectorAll(".reveal");
    if (reveals.length > 0) {
      reveals.forEach((el) => el.classList.add("animate-in"));

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -20px 0px" }
      );
      reveals.forEach((el) => observer.observe(el));
    }
  </script>
</Base>
